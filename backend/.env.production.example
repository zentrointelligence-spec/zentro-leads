# ═══════════════════════════════════════════════════════════════
# LeadRadar — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=LeadRadar
APP_VERSION=2.0.0
ENVIRONMENT=production
DEBUG=False

# ── Security ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

COOKIE_SECURE=True
COOKIE_SAMESITE=lax

# ── Database ─────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg2://user:password@host:5432/zentro_leads
POSTGRES_URL_ASYNC=postgresql+asyncpg://user:password@host:5432/zentro_leads

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:password@host:6379/0

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Google APIs ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaxxxxx
GOOGLE_SEARCH_API_KEY=AIzaxxxxx
GOOGLE_SEARCH_CX=xxxxxxxxx

# ── Email ────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxx
FROM_EMAIL=noreply@leadradar.io

# ── WhatsApp / SMS (Twilio) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Payments (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_GROWTH=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_AGENCY=price_xxxxx

# ── ZIMS Integration ─────────────────────────────────────────
ZIMS_API_URL=https://api.zims.io
ZIMS_INTERNAL_API_KEY=xxxxx

# ── Admin Alerts ─────────────────────────────────────────────
ADMIN_PHONE=+60XXXXXXXXX
ADMIN_EMAIL=moses@zentrointelligence.com

# ── n8n ──────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.yourdomain.com
N8N_API_KEY=n8n_api_xxxxx

# ── Cache TTLs (seconds) ─────────────────────────────────────
CACHE_TTL_LEADS=3600
CACHE_TTL_EMAIL=604800
CACHE_TTL_ICP=86400

# ── Rate Limiting ────────────────────────────────────────────
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
