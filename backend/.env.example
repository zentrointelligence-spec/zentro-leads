# ── App ──────────────────────────────────────────────────────
APP_NAME=Zentro Leads
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Set to false only for local HTTP development
COOKIE_SECURE=false

# ── Database ─────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg2://zl_user:zl_pass@localhost:5433/zentro_leads
POSTGRES_URL_ASYNC=postgresql+asyncpg://zl_user:zl_pass@localhost:5433/zentro_leads

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:zl_redis_pass@localhost:6380/0

# ── ZIMS Integration ─────────────────────────────────────────
ZIMS_API_URL=
ZIMS_INTERNAL_API_KEY=

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Scraping ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
ROTATING_PROXY_URL=

# ── Email ────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@zentro-leads.io

# ── WhatsApp / SMS ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── n8n ──────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=
