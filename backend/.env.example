# ── App ──────────────────────────────────────────────────────
APP_NAME=Zentro Leads
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Set to false only for local HTTP development
COOKIE_SECURE=false

# ── Database ─────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg2://zl_user:zl_pass@localhost:5433/zentro_leads
POSTGRES_URL_ASYNC=postgresql+asyncpg://zl_user:zl_pass@localhost:5433/zentro_leads

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:zl_redis_pass@localhost:6380/0
# Optional: force SlowAPI storage (default: when DEBUG=true, rate limits use memory:// so Redis is not required for login)
# RATE_LIMIT_STORAGE_URI=redis://:zl_redis_pass@localhost:6380/0
ELASTICSEARCH_URL=http://localhost:9200
PINECONE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
PINECONE_INDEX_NAME=zentro-leads
OPENAI_API_KEY=

# ── ZIMS Integration ─────────────────────────────────────────
ZIMS_API_URL=
ZIMS_INTERNAL_API_KEY=

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini (bulk normalization — low cost) ────────────────────
# Get your key from https://aistudio.google.com/app/apikey
# Uses gemini-1.5-flash-8b (cheapest Gemini model)
GOOGLE_GEMINI_API_KEY=

# ── Scraping ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
ROTATING_PROXY_URL=

# ── Email ────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@zentro-leads.io

# ── WhatsApp / SMS ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── n8n ──────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=

# ── ML Scoring Pipeline ──────────────────────────────────────
XGBOOST_MODEL_PATH=models/lead_scorer.json
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MODEL_RETRAIN_THRESHOLD=100

# ── Billplz FPX (Malaysian market) ───────────────────────────
# Get your keys from https://www.billplz.com/enterprise/settings/key
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE=
BILLPLZ_SANDBOX=true
# Change to your public-facing URL in production (ngrok for local dev)
BACKEND_URL=http://localhost:8001

# ── Razorpay UPI (Indian market) ─────────────────────────────
# Get your keys from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
